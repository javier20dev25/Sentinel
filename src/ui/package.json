{
  "name": "sentinel-ui",
  "version": "1.0.0",
  "description": "Sentinel - GitHub Repository Sentinel with powerful local UI",
  "main": "electron/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/javier20dev25/Sentinel.git"
  },
  "author": "Sentinel Team <sentinel@example.com>",
  "private": true,
  "license": "MIT",
  "bin": {
    "sentinel": "./launcher.js",
    "sntl": "./cli/index.js"
  },
  "scripts": {
    "sentinel": "node launcher.js",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "rebuild-native": "electron-rebuild -f -w better-sqlite3",
    "electron:dev": "cross-env NODE_ENV=development concurrently \"vite\" \"wait-on tcp:5173 && electron .\"",
    "electron:build": "electron-rebuild -f -w better-sqlite3 && vite build && npx electron-builder build --win --publish never"
  },
  "build": {
    "appId": "com.sentinel.app",
    "productName": "Sentinel",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": [
        "nsis",
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/sentinel-icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh",
      "shortcutName": "Sentinel Security",
      "artifactName": "${productName} Setup.${ext}",
      "warningsAsErrors": false
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "backend/**/*",
      "cli/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "backend/**/*",
      "cli/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*",
      "node_modules/prebuild-install/**/*",
      "node_modules/node-notifier/**/*"
    ],
    "extraFiles": [
      {
        "from": "build/sentinel.cmd",
        "to": "sentinel.cmd"
      }
    ]
  },
  "dependencies": {
    "acorn": "^8.12.0",
    "acorn-walk": "^8.3.5",
    "axios": "^1.15.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.8.0",
    "chalk": "^4.1.2",
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "framer-motion": "^12.38.0",
    "glob": "^13.0.6",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.7.0",
    "node-notifier": "^10.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.8",
    "wait-on": "^9.0.4"
  }
}
