{
  "name": "sentinel-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Sentinel: Advanced local DevSecOps guardian for GitHub with AI threat intelligence and secure CI sandboxing.",
  "workspaces": [
    "packages/*",
    "samples/*"
  ],
  "scripts": {
    "core:test": "npm test -w packages/core",
    "api:dev": "npm run dev -w packages/api",
    "ui:dev": "npm run dev -w packages/ui",
    "desktop:dev": "npm run dev -w packages/desktop",
    "cli": "node packages/cli/index.js",
    "start": "node packages/api/server/index.js",
    "test": "jest --config jest.config.js"
  },
  "keywords": [],
  "author": "Sentinel Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.1.2",
    "jest": "^30.3.0",
    "typescript": "^5.0.0"
  }
}

