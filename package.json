{
  "name": "sentinel-security-engine",
  "version": "3.8.0",
  "description": "Enterprise-grade auditable security decision engine for CI/CD pipelines",
  "main": "packages/sentinel-cli/cli/index.js",
  "bin": {
    "sentinel": "packages/sentinel-cli/cli/index.js"
  },
  "files": [
    "src/ui/backend",
    "src/ui/cli",
    "rules",
    "docs",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "scan": "node src/ui/cli/index.js scan",
    "release:check": "node scripts/release-smoke-test.js",
    "benchmark": "node scripts/benchmark_suite.js",
    "dashboard": "node src/ui/backend/server/index.js",
    "service": "node src/ui/backend/services/polling.js",
    "ui": "npm --prefix src/ui run electron:dev",
    "start": "node src/start.js",
    "sentinel-link": "node src/ui/cli/index.js link",
    "sentinel-list": "node src/ui/cli/index.js list",
    "sentinel-scan": "node src/ui/cli/index.js scan",
    "test": "node src/ui/backend/scanner/test_scanner.js",
    "prepare": "husky",
    "prepublishOnly": "npm run release:check && npm run benchmark"
  },
  "keywords": [],
  "author": "",
  "license": "BUSSL-1.1",
  "dependencies": {
    "acorn": "8.16.0",
    "acorn-walk": "8.3.5",
    "axois": "^0.0.1-security",
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "node-notifier": "^10.0.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.8"
  },
  "lint-staged": {
    "src/**/*.js": [
      "node src/ui/backend/scanner/test_scanner.js"
    ]
  }
}
